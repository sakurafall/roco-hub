{
  "pages": [
    {
      "path": "pages/home/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "洛克助手·Malt Games"
      }
    },
    {
      "path": "pages/pokedex/index",
      "style": {
        "navigationBarTitleText": "图鉴"
      }
    },
    {
      "path": "pages/tools/index",
      "style": {
        "navigationBarTitleText": "工具箱"
      }
    },
    {
      "path": "pages/discover/index",
      "style": {
        "navigationBarTitleText": "发现"
      }
    },
    {
      "path": "pages/me/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-spirit",
      "pages": [
        {
          "path": "detail/index",
          "style": { "navigationBarTitleText": "精灵详情" }
        }
      ]
    },
    {
      "root": "pages-tools",
      "pages": [
        {
          "path": "type-matchup/index",
          "style": { "navigationBarTitleText": "属性克制" }
        },
        {
          "path": "hatch-predict/index",
          "style": { "navigationBarTitleText": "孵蛋反查" }
        }
      ]
    },
    {
      "root": "pages-me",
      "pages": [
        {
          "path": "favorites/index",
          "style": { "navigationBarTitleText": "我的收藏" }
        },
        {
          "path": "history/index",
          "style": { "navigationBarTitleText": "浏览历史" }
        },
        {
          "path": "appearance/index",
          "style": { "navigationBarTitleText": "外观设置" }
        },
        {
          "path": "feedback/index",
          "style": { "navigationBarTitleText": "意见反馈" }
        },
        {
          "path": "about/index",
          "style": { "navigationBarTitleText": "关于" }
        }
      ]
    }
  ],
  "preloadRule": {
    "pages/home/index": {
      "network": "all",
      "packages": ["pages-spirit"]
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "洛克助手·Malt Games",
    "navigationBarBackgroundColor": "#FFFCF3",
    "backgroundColor": "#FFF8E1"
  },
  "tabBar": {
    "color": "#8A8578",
    "selectedColor": "#FFA62B",
    "backgroundColor": "#FFFCF3",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/pokedex/index",
        "text": "图鉴",
        "iconPath": "static/tabbar/pokedex.png",
        "selectedIconPath": "static/tabbar/pokedex-active.png"
      },
      {
        "pagePath": "pages/tools/index",
        "text": "工具",
        "iconPath": "static/tabbar/tools.png",
        "selectedIconPath": "static/tabbar/tools-active.png"
      },
      {
        "pagePath": "pages/discover/index",
        "text": "发现",
        "iconPath": "static/tabbar/discover.png",
        "selectedIconPath": "static/tabbar/discover-active.png"
      },
      {
        "pagePath": "pages/me/index",
        "text": "我的",
        "iconPath": "static/tabbar/me.png",
        "selectedIconPath": "static/tabbar/me-active.png"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  }
}
