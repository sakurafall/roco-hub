{
  "name": "loka-spirit-helper",
  "version": "0.0.1",
  "private": true,
  "description": "洛克助手 · Malt Games Engine · uni-app 3 + Vue 3 + TS + Pinia 骨架",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue,.js,.cjs",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "test": "vitest run",
    "gen:tabbar": "node scripts/generate-tabbar-icons.mjs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080420251103001",
    "dayjs": "^1.11.13",
    "pinia": "^2.2.4",
    "pinyin-pro": "^3.26.0",
    "uview-plus": "^3.4.18",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.28.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "sass": "^1.79.4",
    "typescript": "^5.4.5",
    "vite": "5.2.8",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.1.6"
  },
  "lint-staged": {
    "*.{ts,vue,js,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild",
      "vue-demi"
    ]
  }
}
